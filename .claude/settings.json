{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo fork --remote=upstream*)",
      "Bash(osc sr*)",
      "Bash(osc submitrequest*)",
      "Bash(osc submitreq*)",
      "Bash(osc createrequest*)",
      "Bash(osc copypac*)",
      "Bash(osc delete*)",
      "Bash(osc rdelete*)",
      "Bash(osc undelete*)",
      "Bash(osc lock*)",
      "Bash(osc unlock*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(zypper *)",
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(dnf *)",
      "Bash(yum *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv*)",
      "Bash(cat ~/.config/osc/oscrc*)",
      "Bash(cat ~/.netrc*)",
      "Bash(cat ~/.config/gh/*)",
      "Bash(cat ~/.ssh/id_*)",
      "Bash(cat ~/.aws/*)",
      "Read(/home/spectro/.config/osc/oscrc)",
      "Read(/home/spectro/.netrc)",
      "Read(/home/spectro/.config/gh/hosts.yml)",
      "Read(/home/spectro/.ssh/id_*)",
      "Read(/home/spectro/.gnupg/**)",
      "Read(/home/spectro/.aws/**)",
      "Read(/home/spectro/.azure/**)"
    ],
    "allow": [
      "Bash(git push origin*)",
      "Bash(git push fork*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git commit*)",
      "Bash(git add*)",
      "Bash(git worktree*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh api *)",
      "Bash(gh auth status*)",
      "Bash(osc results*)",
      "Bash(osc whois*)",
      "Bash(osc ls*)",
      "Bash(osc co*)",
      "Bash(osc checkout*)",
      "Bash(osc ci*)",
      "Bash(osc commit*)",
      "Bash(osc up*)",
      "Bash(osc add*)",
      "Bash(osc rm*)",
      "Bash(osc vc*)",
      "Bash(osc build*)",
      "Bash(osc buildlog*)",
      "Bash(osc service*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash .claude/hooks/block-upstream-actions.sh", "timeout": 3},
          {"type": "command", "command": "bash .claude/hooks/block-credential-leak.sh", "timeout": 2}
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {"type": "command", "command": "bash .claude/hooks/block-credential-leak.sh", "timeout": 2}
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {"type": "command", "command": "bash .claude/hooks/block-self-modify.sh", "timeout": 2}
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "bash .claude/hooks/scrub-env.sh", "timeout": 2}
        ]
      }
    ]
  }
}
