# Runtime state — identity, posture, queue, worktrees.
# NEVER commit these: state/config.json contains the user's GH/OBS login,
# state/.lsr-maintainer-state.json contains their PR cursors + role tracking,
# state/.bootstrap-state.json contains a host fingerprint.
state/config.json
state/.lsr-maintainer-state.json
state/.bootstrap-state.json
state/.setup-complete.json
state/.run.pid
state/PENDING_REVIEW.md
state/LSR_PROGRESS.md
state/cache/
state/worktrees/

# Self-contained runtime tree — ISOs, role clones, worktrees, tox venv,
# OBS checkout, audit logs, transcripts, OBS-package context. Anything
# created by 'make install' or the nightly cron lands here.
# Wipe with `rm -rf var/` for a full reset.
var/

# Belt-and-suspenders: defense against accidental commits of vault
# passwords or unencrypted SCC creds even if someone moves them outside
# var/. The 'make scc-vault-init' flow already puts these under var/.
.vault_pwd
**/.vault_pwd
vault-suseconnect.yml
**/vault-suseconnect.yml
!assets/playbooks/vault-suseconnect.yml.example

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/

# Test artefacts
tests/.tmp/
tests/.coverage

# Editor
.vscode/
.idea/
*.swp
*~
